# =============================================================================
# CloudNotes - Environment Variable Reference (.env.example)
# Copy this file to ".env" for local development. In production, set these
# as real environment variables in your platform's deploy form instead of
# committing a .env file. Every variable has a safe default so the app boots
# with ZERO configuration, but defaults marked "CHANGE IN PRODUCTION" must be
# overridden before a real deployment.
# =============================================================================

# -----------------------------------------------------------------------------
# Database connectivity (PostgreSQL) - a separate service/container
# -----------------------------------------------------------------------------
# Hostname of the database service. In docker-compose this matches the
# "db" service name. On a Marketplace platform, point this at the managed/
# linked database instance.
DB_SERVER=db
# Database port. 5432 is the standard PostgreSQL port.
DB_PORT=5432
# Database name used by the app.
DB_NAME=cloudnotes
# Database user the app authenticates as.
DB_USER=cloudnotes
# Database password. CHANGE IN PRODUCTION - this default is for local/dev only.
DB_PASSWD=cloudnotes_dev_password
# Enable SSL for the DB connection (set to "true" for most managed cloud DBs).
DB_SSL=false

# -----------------------------------------------------------------------------
# App identity / networking
# -----------------------------------------------------------------------------
# Public domain/hostname the app is served from (used for links, cookies, CORS).
APP_DOMAIN=localhost
# Port the HTTP server listens on inside the container.
PORT=8080
# Force the public URL scheme used when building absolute links (http|https).
APP_URL_SCHEME=http

# -----------------------------------------------------------------------------
# Bootstrap / install behavior
# -----------------------------------------------------------------------------
# 1 = run the unattended first-boot install (schema + seed + admin account).
# 0 = skip auto-install (useful once the DB is already provisioned).
# Safe to leave as 1 permanently: install is idempotent and skips itself once
# the app_meta.installed flag is set in the database.
APP_INSTALL_AUTO=1
# Optional. Email for the auto-created admin account.
APP_ADMIN_EMAIL=admin@example.com
# Optional. Username for the auto-created admin account.
APP_ADMIN_USER=admin
# Optional. Password for the auto-created admin account.
# CHANGE IN PRODUCTION - if left blank, a strong random password is generated
# and printed ONCE to the container logs on first boot.
APP_ADMIN_PASSWORD=

# -----------------------------------------------------------------------------
# Storage
# -----------------------------------------------------------------------------
# Path inside the container for persistent data (mount a volume here so data
# survives restarts/redeploys).
APP_DATA_DIR=/app/data

# -----------------------------------------------------------------------------
# Session / security
# -----------------------------------------------------------------------------
# Secret used to sign session cookies. CHANGE IN PRODUCTION to a long random
# string (e.g. "openssl rand -hex 32").
SESSION_SECRET=dev_only_insecure_session_secret_change_me

# -----------------------------------------------------------------------------
# Runtime / production
# -----------------------------------------------------------------------------
# development | production
NODE_ENV=production
# Alias some platforms prefer; keep in sync with NODE_ENV.
APP_ENV=production
# error | warn | info | debug
LOG_LEVEL=info
